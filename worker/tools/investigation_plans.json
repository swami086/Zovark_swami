{
    "brute_force": {
        "description": "Investigate brute force / credential stuffing attacks by counting failed auth attempts, extracting source IPs, and scoring based on volume and source diversity",
        "plan": [
            {"tool": "parse_auth_log", "args": {"raw_log": "$raw_log"}},
            {"tool": "extract_ipv4", "args": {"text": "$raw_log"}},
            {"tool": "extract_usernames", "args": {"text": "$raw_log"}},
            {"tool": "count_pattern", "args": {"text": "$raw_log", "pattern": "(?i)fail|denied|invalid|error|rejected"}},
            {
                "condition": "$step4 > 50",
                "if_true": {"tool": "score_brute_force", "args": {"failed_count": "$step4", "unique_sources": "$step2.count", "timespan_minutes": 60}},
                "if_false": {"tool": "score_brute_force", "args": {"failed_count": "$step4", "unique_sources": "$step2.count", "timespan_minutes": 120}}
            },
            {"tool": "correlate_with_history", "args": {"ioc_values": "$step2", "lookback_hours": 72, "history_context": "$correlation_context"}},
            {"tool": "map_mitre", "args": {"technique_ids": ["T1110", "T1110.001", "T1110.003"]}}
        ]
    },
