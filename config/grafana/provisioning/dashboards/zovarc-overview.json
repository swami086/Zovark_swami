{
  "annotations": { "list": [] },
  "description": "ZOVARC SOC Platform — investigation pipeline, LLM performance, and infrastructure health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Investigations",
      "description": "Total investigations processed across all tenants",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_investigations_total", "legendFormat": "Total", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Success Rate",
      "description": "Completed tasks / total tasks as a percentage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "zovarc_temporal_completed_tasks_1h{task_queue=\"zovarc-tasks\"} / (zovarc_temporal_completed_tasks_1h{task_queue=\"zovarc-tasks\"} + zovarc_temporal_failed_tasks_1h{task_queue=\"zovarc-tasks\"} + 0.001) * 100",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Pending Tasks",
      "description": "Tasks waiting in Temporal queue",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_temporal_pending_tasks{task_queue=\"zovarc-tasks\"}", "legendFormat": "Pending", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Failed (1h)",
      "description": "Task failures in the last hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_temporal_failed_tasks_1h{task_queue=\"zovarc-tasks\"}", "legendFormat": "Failed", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "LLM Calls — Total",
      "description": "Total LLM API calls tracked via llm_audit_log",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_llm_tokens_total", "legendFormat": "Tokens", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "LLM Avg Latency",
      "description": "Average LLM request duration (seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_llm_request_seconds", "legendFormat": "Avg (s)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "title": "Worker Status",
      "description": "Whether ZOVARC workers are running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_up", "legendFormat": "Workers", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Sigma Rules",
      "description": "Active detection rules generated by the pipeline",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_sigma_rules_total", "legendFormat": "Rules", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Entities Tracked",
      "description": "Total entities (IPs, domains, hashes) in the knowledge graph",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_entities_total", "legendFormat": "Entities", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Active Tasks",
      "description": "Currently executing Temporal workflows",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_temporal_active_tasks{task_queue=\"zovarc-tasks\"}", "legendFormat": "Active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Task Queue Depth",
      "description": "Pending and active task counts over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_temporal_pending_tasks{task_queue=\"zovarc-tasks\"}", "legendFormat": "Pending", "refId": "A" },
        { "expr": "zovarc_temporal_active_tasks{task_queue=\"zovarc-tasks\"}", "legendFormat": "Active", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto",
            "spanNulls": true
          }
        }
      }
    },
    {
      "title": "Task Throughput",
      "description": "Completed and failed tasks over time (1h rolling window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_temporal_completed_tasks_1h{task_queue=\"zovarc-tasks\"}", "legendFormat": "Completed (1h)", "refId": "A" },
        { "expr": "zovarc_temporal_failed_tasks_1h{task_queue=\"zovarc-tasks\"}", "legendFormat": "Failed (1h)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed (1h)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "LLM Latency Over Time",
      "description": "Average LLM request duration trending",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_llm_request_seconds", "legendFormat": "LLM Avg Duration (s)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          },
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "title": "Verdicts Breakdown",
      "description": "Distribution of investigation verdicts (true_positive, false_positive, etc.)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_verdict_total", "legendFormat": "{{verdict}}", "refId": "A" }
      ]
    },
    {
      "title": "Tasks by Type",
      "description": "Distribution of investigation types (brute_force, sql_injection, etc.)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "zovarc_worker_tasks_by_type", "legendFormat": "{{task_type}}", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["zovarc", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "title": "ZOVARC -- Overview",
  "uid": "zovarc-overview"
}
