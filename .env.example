# HYDRA MVP — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=change_me

# LiteLLM gateway
LITELLM_MASTER_KEY=change_me

# MinIO object storage
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me

# LLM provider (OpenRouter cloud or local)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# JWT signing secret (min 32 chars)
JWT_SECRET=change_me

# Optional overrides
HYDRA_ENV=development
HYDRA_LOG_LEVEL=info
HYDRA_LLM_MODEL=fast
TEMPORAL_ADDRESS=temporal:7233
