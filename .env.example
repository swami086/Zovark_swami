# HYDRA MVP — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# PostgreSQL
POSTGRES_PASSWORD=change_me

# LiteLLM gateway
LITELLM_MASTER_KEY=change_me

# MinIO object storage
MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me

# LLM providers (Sprint 5: multi-provider fallback chains)
GROQ_API_KEY=gsk_your_key_here
OPENROUTER_API_KEY=sk-or-v1-your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# JWT signing secret (REQUIRED, min 32 chars)
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Optional overrides
HYDRA_ENV=development
HYDRA_LOG_LEVEL=info
# CORS origins (comma-separated, default: http://localhost:3000)
# HYDRA_CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com
# HYDRA_LLM_MODEL — leave unset to use per-tier routing (hydra-fast/standard/reasoning)
# Set to a single model name to force all tiers through one provider
TEMPORAL_ADDRESS=temporal:7233
HYDRA_SIMILARITY_THRESHOLD=0
# Investigations below this risk score are flagged for human review (default: 60)
# HYDRA_HUMAN_REVIEW_THRESHOLD=60

# Zovark v3 Settings (Pydantic)
ZOVARK_DB_PASSWORD=your-db-password-here
ZOVARK_REDIS_PASSWORD=your-redis-password-here
ZOVARK_LLM_KEY=your-ollama-key-here
