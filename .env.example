# ============================================================
# Zovark v3.2 Sovereign Appliance — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ============================================================

# ─── GPU / CUDA ─────────────────────────────────────────────
# GPU tier: determines which compose overlay to use
#   dev        = single inference container (distroless.yml)
#   enterprise = dual inference containers (distroless.yml + enterprise.yml)
ZOVARK_GPU_TIER=dev

# CUDA compute capability for llama.cpp build
#   75 = Turing (RTX 2070/2080, T4)
#   86 = Ampere (RTX 3060/3070/3080/3090, A5000, A6000)
#   89 = Ada Lovelace (RTX 4060/4070/4080/4090, L40S)
#   90 = Hopper (H100)
CUDA_ARCH=86

# ─── MODEL FILES (Dev Tier — single inference) ─────────────
# Place GGUF files in ./models/ directory
ZOVARK_MODEL_FILE=llama-3.2-3b-instruct.Q4_K_M.gguf
ZOVARK_MODEL_ALIAS=llama3.2:3b
ZOVARK_CTX_SIZE=4096
ZOVARK_PARALLEL=4

# ─── MODEL FILES (Enterprise Tier — dual inference) ─────────
# Uncomment these when using docker-compose.enterprise.yml
# ZOVARK_MODEL_FILE_FAST=llama-3.2-3b-instruct.Q4_K_M.gguf
# ZOVARK_MODEL_ALIAS_FAST=llama3.2:3b
# ZOVARK_CTX_SIZE_FAST=4096
# ZOVARK_MODEL_FILE_CODE=llama-3.1-8b-instruct.Q4_K_M.gguf
# ZOVARK_MODEL_ALIAS_CODE=llama3.1:8b
# ZOVARK_CTX_SIZE_CODE=8192

# ─── MODEL ROUTING (worker) — Ticket 8 defaults ────────────
ZOVARK_MODEL_FAST=gpt-4o-mini
ZOVARK_MODEL_CODE=gpt-4o-mini

# ─── DIAGNOSTICS SIDECAR ───────────────────────────────────
# Bearer token required to access /diag/* endpoints.
# Generate with: openssl rand -hex 32
DIAG_AUTH_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── BREAK-GLASS ACCESS ────────────────────────────────────
# Bcrypt hash of the break-glass password for emergency admin access.
# Generate with: htpasswd -nbBC 12 "" 'YourPassword' | cut -d: -f2
ZOVARK_BREAKGLASS_PASSWORD_HASH=

# ─── DATABASE ───────────────────────────────────────────────
POSTGRES_USER=zovark
POSTGRES_PASSWORD=hydra_dev_2026
POSTGRES_DB=zovark

# Pydantic Settings (worker)
ZOVARK_DB_PASSWORD=hydra_dev_2026

# ─── REDIS ──────────────────────────────────────────────────
REDIS_PASSWORD=hydra-redis-dev-2026
ZOVARK_REDIS_PASSWORD=hydra-redis-dev-2026

# ─── JWT ────────────────────────────────────────────────────
# REQUIRED: minimum 32 characters. Generate with: openssl rand -base64 64
JWT_SECRET=zovark-jwt-secret-dev-2026-CHANGE-ME-IN-PRODUCTION-min-32-chars

# ─── LLM (Ticket 8 — OpenAI primary) ─────────────────────────
# REQUIRED for cloud inference: set OPENAI_API_KEY (standard OpenAI env name).
# Also accepted: ZOVARK_OPENAI_API_KEY. Legacy local bearer: ZOVARK_LLM_KEY.
OPENAI_API_KEY=
ZOVARK_LLM_PROVIDER=openai
ZOVARK_LLM_BASE_URL=https://api.openai.com
ZOVARK_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
ZOVARK_LLM_ENDPOINT_FAST=https://api.openai.com/v1/chat/completions
ZOVARK_LLM_ENDPOINT_CODE=https://api.openai.com/v1/chat/completions
#
# Local llama.cpp / Ollama (air-gap): set ZOVARK_LLM_PROVIDER=local and point endpoints
# ZOVARK_LLM_PROVIDER=local
# ZOVARK_LLM_ENDPOINT=http://zovark-inference:8080/v1/chat/completions
# ZOVARK_LLM_KEY=sk-local-dev

# Approximate max input context (char/4 heuristic); over-budget sections are tail-truncated
ZOVARK_CONTEXT_TOKEN_BUDGET=12000
# Optional absolute path to a GBNF grammar file (overrides named grammars/)
# ZOVARK_GRAMMAR_FILE=/path/to/verdict.gbnf

# External attack-surface / threat API (default off — air-gap safe)
ZOVARK_THREAT_INTEL_ENABLED=false

# DPO forge: default NVIDIA API; set to local llama-server chat URL for air-gap
# ZOVARK_DPO_FORGE_ENDPOINT=http://zovark-inference:8080/v1/chat/completions
# Offline DPO base weights for scripts/dpo_train.py (Unsloth HF id); default remains small Qwen in repo
# ZOVARK_DPO_BASE_MODEL=unsloth/Meta-Llama-3.2-3B-Instruct-bnb-4bit

# Optional override for MITRE→compliance YAML (worker/governance/)
# ZOVARK_COMPLIANCE_RULES_PATH=/path/to/compliance_rules.yaml

# ─── BURST PROTECTION ──────────────────────────────────────
# Smart batcher settings
ZOVARK_BATCH_WINDOW_SECONDS=60
ZOVARK_BATCH_MAX_SIZE=500

# Circuit breaker thresholds (LLM failure counts)
ZOVARK_CB_YELLOW=50
ZOVARK_CB_RED=100
ZOVARK_CB_RECOVERY=25

# Assess stage timeout (seconds)
ZOVARK_ASSESS_TIMEOUT=45

# Risk score threshold for human review flag
ZOVARK_HUMAN_REVIEW_THRESHOLD=60

# Redis code cache TTL (seconds, default 24h)
ZOVARK_CODE_CACHE_TTL=86400

# Redis deduplication
DEDUP_ENABLED=true

# ─── EXECUTION MODE ────────────────────────────────────────
# tools  = v3 deterministic tool-calling pipeline (default)
# sandbox = v2 Docker sandbox pipeline (legacy)
ZOVARK_EXECUTION_MODE=tools
ZOVARK_MODE=full
ZOVARK_FAST_FILL=true

# ─── CONCURRENCY ────────────────────────────────────────────
ZOVARK_MAX_CONCURRENT_ACTIVITIES=16
ZOVARK_MAX_CONCURRENT_WORKFLOWS=32

# ─── OBSERVABILITY ──────────────────────────────────────────
# Default: in-cluster SigNoz OTLP (docker compose includes zovark-signoz-collector).
# For Docker Desktop sending to a host-run collector: use http://host.docker.internal:4318
# Go API + worker export traces/metrics here (Ticket 7).
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://zovark-signoz-collector:4318
ZOVARK_OTEL_ENDPOINT=http://zovark-signoz-collector:4318
# Dashboard browser RUM (Ticket 10): compose passes OTEL_ENABLED into the dashboard image at build time.
# After toggling OTEL_ENABLED, rebuild: docker compose build dashboard && docker compose up -d dashboard
# Local Vite: dashboard/.env.local → VITE_OTEL_ENABLED=true and VITE_OTEL_EXPORTER_OTLP_TRACES_URL=http://127.0.0.1:4318/v1/traces
# Root log level for OTLP export to SigNoz (DEBUG, INFO, WARNING, …). Compose defaults worker to DEBUG.
# ZOVARK_LOG_LEVEL=INFO
# SigNoz MCP (Cursor ~/.cursor/mcp.json): SIGNOZ_URL=http://127.0.0.1:3301
# Unified SigNoz v0.76+ serves UI + API on that port. Official signoz-mcp-server uses PAT on SIGNOZ-API-KEY;
# self-hosted OSS uses POST /api/v4/query_range (local MCP fork translates builder queries accordingly).
# SIGNOZ_API_KEY = Personal Access Token from SigNoz UI (Settings → API keys). Header: SIGNOZ-API-KEY.
# Optional: SIGNOZ_JWT or SIGNOZ_BEARER_TOKEN = login accessJwt for tools that return 401 with PAT only (e.g. list dashboards on some EE builds).
# Upgrading from query-service ≤0.64: docker compose pull && up -d; if SQLite errors, `docker volume rm zovark_signoz-query-data` and recreate admin + PAT.

# ─── ED25519 UPDATE VERIFICATION ────────────────────────────
# Path to the Ed25519 public key used to verify .zvk update bundles.
# Generate keypair with: python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; ..."
# See docs/AIRGAP_UPDATES.md for full instructions.
ZOVARK_UPDATE_PUBLIC_KEY_PATH=./keys/update-verify.pub

# ─── OPTIONAL DATA PLANE (SurrealDB + Redpanda + DuckDB) ───
# Start services: docker compose -f docker-compose.yml -f docker-compose.data-plane.yml --profile data-plane up -d
# Match SurrealDB container: docker-compose sets SURREAL_ROOT_PASSWORD for the DB; worker uses ZOVARK_SURREAL_*.
# SURREAL_ROOT_PASSWORD=change-me-surreal
# ZOVARK_REDPANDA_ENABLED=false
# ZOVARK_SURREAL_ENABLED=false
# ZOVARK_DUCKDB_ENABLED=false
# ZOVARK_REDPANDA_BROKERS=redpanda:9092
# ZOVARK_REDPANDA_TOPIC_INVESTIGATIONS=zovark.investigations.completed
# FineTuningPipelineWorkflow publishes platform.finetuning.data_ready.{tenant_id} when export completes (model flywheel).
# ZOVARK_SURREAL_HTTP_URL=http://surrealdb:8000
# ZOVARK_SURREAL_USER=root
# ZOVARK_SURREAL_PASSWORD=change-me-surreal
# ZOVARK_SURREAL_NS=zovark
# ZOVARK_SURREAL_DB=core
# ZOVARK_DUCKDB_PATH=/data/duckdb/analytics.duckdb
# Flink (training-data pipeline): docker compose -f docker-compose.yml -f docker-compose.data-plane.yml --profile flink up -d

# ─── TICKET 5 — Customer collection + platform ingest ───────
# Customer appliance: enable sidecar + buffer volume (profile collection)
# ZOVARK_COLLECTION_ENABLED=true
# ZOVARK_PLATFORM_ENDPOINT=https://your-platform.example/api/v1/platform/training-data/ingest
# ZOVARK_PLATFORM_API_KEY=shared-bearer-secret
# Split URL for Fluent Bit 3 YAML (docker compose sets these from .env):
# ZOVARK_PLATFORM_HOST=api
# ZOVARK_PLATFORM_PORT=8090
# ZOVARK_PLATFORM_URI=/api/v1/platform/training-data/ingest
# ZOVARK_PLATFORM_TLS=off
# ZOVARK_CUSTOMER_ID=00000000-0000-0000-0000-000000000001
# Server (API): must match customer Bearer token (gateway: /api/v1/platform/training-data/ingest)
# ZOVARK_PLATFORM_INGEST_BEARER=same-as-ZOVARK_PLATFORM_API_KEY
# Optional header aliases: X-Customer-ID (preferred), X-Zovark-Customer-Id; fallback system tenant UUID
# Keyed anonymization for finetuning export (HMAC); falls back to ZOVARK_PLATFORM_API_KEY if unset
# ZOVARK_COLLECTION_ANONYMIZATION_KEY=
# Merge adapter base HF id (also --base-model on CLI)
# ZOVARK_MERGE_BASE_MODEL=meta-llama/Llama-3.2-3B-Instruct
# Quantization gate (scripts/convert_to_gguf.sh)
# ZOVARK_GATE_BASELINE_MODEL=fast
# ZOVARK_GATE_CANDIDATE_MODEL=quantized-alias
# ZOVARK_IMATRIX_FILE=artifacts/imatrix.dat
# ZOVARK_SKIP_VERDICT_GATE=0

# ─── INFRASTRUCTURE (usually left as defaults) ─────────────
TEMPORAL_ADDRESS=temporal:7233
# DATABASE_URL and REDIS_URL are constructed by compose from above values
