apiVersion: v1
kind: Secret
metadata:
  name: hydra-db-credentials
  namespace: hydra
  labels:
    app: hydra
type: Opaque
stringData:
  password: "CHANGE_ME"
  pgbouncer-url: "postgresql://hydra:CHANGE_ME@pgbouncer:5432/hydra"
  direct-url: "postgresql://hydra:CHANGE_ME@postgres:5432/hydra"
---
apiVersion: v1
kind: Secret
metadata:
  name: hydra-api-secrets
  namespace: hydra
  labels:
    app: hydra
type: Opaque
stringData:
  jwt-secret: "CHANGE_ME"
  litellm-master-key: "CHANGE_ME"
  openrouter-api-key: "CHANGE_ME"
