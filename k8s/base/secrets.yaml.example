apiVersion: v1
kind: Secret
metadata:
  name: zovark-db-credentials
  namespace: zovark
  labels:
    app: zovark
type: Opaque
stringData:
  password: "CHANGE_ME"
  pgbouncer-url: "postgresql://zovark:CHANGE_ME@pgbouncer:5432/zovark"
  direct-url: "postgresql://zovark:CHANGE_ME@postgres:5432/zovark"
---
apiVersion: v1
kind: Secret
metadata:
  name: zovark-api-secrets
  namespace: zovark
  labels:
    app: zovark
type: Opaque
stringData:
  jwt-secret: "CHANGE_ME"
  litellm-master-key: "CHANGE_ME"
  openrouter-api-key: "CHANGE_ME"
