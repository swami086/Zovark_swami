apiVersion: v1
kind: Secret
metadata:
  name: zovarc-db-credentials
  namespace: zovarc
  labels:
    app: zovarc
type: Opaque
stringData:
  password: "CHANGE_ME"
  pgbouncer-url: "postgresql://zovarc:CHANGE_ME@pgbouncer:5432/zovarc"
  direct-url: "postgresql://zovarc:CHANGE_ME@postgres:5432/zovarc"
---
apiVersion: v1
kind: Secret
metadata:
  name: zovarc-api-secrets
  namespace: zovarc
  labels:
    app: zovarc
type: Opaque
stringData:
  jwt-secret: "CHANGE_ME"
  litellm-master-key: "CHANGE_ME"
  openrouter-api-key: "CHANGE_ME"
