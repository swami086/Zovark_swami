# HYDRA Secrets — copy to .env and fill in real values
# NEVER commit the .env file (it's in .gitignore)

# Database
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# JWT Authentication
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# LiteLLM Gateway
LITELLM_MASTER_KEY=CHANGE_ME_litellm_key

# NATS Message Broker
NATS_USER=hydra
NATS_PASSWORD=CHANGE_ME_nats_password

# MinIO Object Storage
MINIO_ROOT_USER=hydra
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# Admin Account (created on first boot)
HYDRA_ADMIN_EMAIL=admin@yourdomain.com
HYDRA_ADMIN_PASSWORD=CHANGE_ME_admin_password

# Encryption
HYDRA_ENCRYPTION_KEY=CHANGE_ME_encryption_key
