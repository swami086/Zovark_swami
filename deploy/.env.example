# ============================================================
# HYDRA Production Configuration
# Copy to .env and fill in all values marked CHANGE_ME
# ============================================================

# --- Database ---
POSTGRES_USER=hydra
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=hydra

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_password

# --- Authentication ---
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
HYDRA_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- LLM ---
# Point to your LLM endpoint (llama.cpp, Ollama, or cloud)
LITELLM_URL=http://host.docker.internal:11434/v1/chat/completions
LITELLM_MASTER_KEY=CHANGE_ME_litellm_key
HYDRA_LLM_MODEL=qwen2.5:14b

# --- Ports ---
API_PORT=8090
DASHBOARD_PORT=3000

# --- Admin (first boot) ---
HYDRA_ADMIN_EMAIL=admin@yourdomain.com
HYDRA_ADMIN_PASSWORD=CHANGE_ME_admin_password
